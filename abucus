#!/bin/sh
set_variables() {
	OS=$(source /etc/os-release; echo "${ID,,}")
	CPU_ARCH="$(uname -m)"
	export ABUCUS_DIR=$(cd -- "$(dirname -- "${0}")" && pwd -P)
	export ABUCUS_SCRIPT="${ABUCUS_DIR}/${0##*/}"
	export ABUCUS_VERSION="$(shasum -a 256 "${ABUCUS_SCRIPT}" | cut -c1-8)"
	export ABUCUS_CONF="${ABUCUS_DIR}/abucus.conf"
	export ABUCUS_HOME="${ABUCUS_DIR}/home"
	if [[ -f "${ABUCUS_CONF}" ]]; then
		source "${ABUCUS_CONF}"
	fi
	export ABUCUS_EDITOR="${ABUCUS_EDITOR:-/usr/bin/nano}"
	export ABUCUS_PROJECTS_DIR="${ABUCUS_SRC_DIR:-${ABUCUS_DIR}/projects}"
	INSTALL_DIR="${INSTALL_DIR:-/usr}"
	export ABUCUS_INSTALL_DIR="${LOCAL_INSTALL_DIR:-${ABUCUS_DIR}/install}"
	export ABUCUS_ARCHIVE_DIR="${ARCHIVE_DIR:-${ABUCUS_DIR}/archive}"
	BUILD_TYPE="${BUILD_TYPE:-Release}"
	CUSTOM_VAR="${CUSTOM_VAR:-${OS}}"
	local file_managers=("nautilus" "dolphin" "thunar" "nemo" "caja" "pcmanfm" "pcmanfm-qt")
	for i in "${file_managers[@]}"; do
		if [[ "$(command -v "${i}")" ]]; then
			ABUCUS_FM="$(command -v "${i}")"
			break
		fi
	done
	ADMIN=()
	if [[ "${UID}" != 0 ]]; then
		if [[ "$(command -v sudo)" ]]; then
			ADMIN=(sudo)
		elif [[ "$(command -v doas)" ]]; then
			ADMIN=(doas)
		else
			say "${R}Cannot get root access${N}"
		fi
	fi
	export ABUCUS_LOGO="------------------------------------------------------------
    \     __ )   |   |   ___|  |   |   ___| 
   _ \    __ \   |   |  |      |   | \___ \ 
  ___ \   |   |  |   |  |      |   |       |
_/    _\ ____/  \___/  \____| \___/  _____/ 
${ABUCUS_SCRIPT}
${W}Abucus Version:${N} ${E}shasum${N} [${G}${ABUCUS_VERSION}${N}]
------------------------------------------------------------"
}
setup_project() {
	directories=("${PROJECT_DIR}/home.${PROJECT_NAME}" "${PROJECT_DIR}/build.${PROJECT_NAME}" "${PROJECT_DIR}/files.${PROJECT_NAME}" "${PROJECT_DIR}/install.${PROJECT_NAME}/bin" "${PROJECT_DIR}/install.${PROJECT_NAME}/include" "${PROJECT_DIR}/install.${PROJECT_NAME}/lib" "${PROJECT_DIR}/install.${PROJECT_NAME}/lib64" "${PROJECT_DIR}/archive.${PROJECT_NAME}")
	for i in "${directories[@]}"; do
		make_directory "${i}"
	done
	if [[ ! -f "${PROJECT_SCRIPT}" ]]; then
		printf '%s' "#!/bin/bash
# Abucus ${ABUCUS_VERSION}
# ${PROJECT_NAME}
# ${PROJECT_URL}
PROJECT_NAME=\"${PROJECT_NAME}\"
PROJECT_URL=\"${PROJECT_URL}\"
PROJECT_NOTES=\"${PROJECT_NOTES}\"
clean_project() {
${clean_function:-${clean_project}}
}
configure_project() {
${configure_function:-${configure_project}}
}
build_project() {
${build_function:-${build_project}}
}
install_project() {
${install_function:-	${install_project}}
}
run_project() {
${run_function:-${run_project}}
}
clone_project() {
	if [[ ! -d \"\${SRC_DIR}\" ]]; then
		git clone --recursive --branch \"\${BRANCH}\" \"\${PROJECT_URL}\" \"\${SRC_DIR}\"
		if [[ \"\${?}\" != 0 ]]; then
			say \"\${R}Failed to clone\${N} [ \${G}\${PROJECT_URL}\${N} ]\"
			remove \"\${SRC_DIR}\"
			exit 1
		fi
	fi
}
update_project() {
	if [[ -d \"\${SRC_DIR}\" ]]; then
		git -C \"\${SRC_DIR}\" pull
		git -C \"\${SRC_DIR}\" submodule init
		git -C \"\${SRC_DIR}\" submodule update
	elif [[ \"\${PROJECT_URL}\" ]]; then
		clone_project
		git -C \"\${SRC_DIR}\" pull
		git -C \"\${SRC_DIR}\" submodule init
		git -C \"\${SRC_DIR}\" submodule update
	else
		say \"[ \${G}\${SRC_DIR}\${N} ] \${R}does not exist\${N}\"
	fi
}
archive_project() {
	local output=\"\${ARCHIVE_DIR}/archive.\${PROJECT_NAME}.\${SRC_VERSION}.tar.zst\"
	if [[ ! -f \"\${output}\" ]]; then
		tar -cpvf - --xattrs-include='*.*' --numeric-owner \"\${SRC_DIR}\" \"\${BUILD_DIR}\" \"\${FILES_DIR}\" \"\${INSTALL_DIR}\" \"\${PROJECT_SCRIPT}\" | zstd -k --ultra -22 -T0 -o \"\${output}\" -
	else
		say \"\${R}Archive already exists\${N} [\${G} \${output} \${N}]\"
	fi
}
abucus_dependencies() {
${abucus_functions:-${abucus_project}}
}
dependencies() {
${dependency_function:-${dependency_project}}
}
colors() {
	L=\"\$(tput setaf 0)\"
	R=\"\$(tput setaf 1)\"
	G=\"\$(tput setaf 2)\"
	Y=\"\$(tput setaf 3)\"
	B=\"\$(tput setaf 4)\"
	P=\"\$(tput setaf 5)\"
	E=\"\$(tput setaf 6)\"
	W=\"\$(tput bold)\$(tput setaf 7)\"
	D=\"\$(tput setaf 8)\"
	N=\"\$(tput sgr0)\"
}
remove() {
	local prompt=\"\$(say \"\${W}Deleting\${N} [\${R}\${1}\${N}] Continue? [\${G}Y/n\${N}]: \")\"
	if [[ -w \"\$(dirname \"\${1}\")\" ]]; then
		if [[ ! \"\${2}\" ]]; then
			read -p \"\${prompt}\" p
		fi
		if [[ \"\${p}\" != [nN] ]] || [[ \"\${2}\" ]]; then
			rm -Rf \"\${1}\"
		else
			say \"\${W}Skipping deletion of\${N} [\${G}\${1}\${N}]\"
		fi
	else
		if [[ ! \"\${2}\" ]]; then
			read -p \"\${prompt}\" p
		fi
		if [[ \"\${p}\" != [nN] ]] || [[ \"\${2}\" ]]; then
			\"\${ADMIN[@]}\" rm -Rf \"\${1}\"
		else
			say \"\${W}Skipping deletion of\${N} [\${G}\${1}\${N}]\"
		fi
	fi
}
make_directory() {
	if [[ ! -d \"\${1}\" ]]; then
		say \"\${W}Creating directory\${N} [\${G}\${1}\${N}]\"
		local parent=\"\$(dirname \"\${1}\")\"
		while [[ ! -d \"\${parent}\" ]]; do
			parent=\"\$(dirname \"\${parent}\")\"
		done
		if [[ -w \"\${parent}\" ]]; then
			mkdir -p \"\${1}\"
		else
			\"\${ADMIN[@]}\" mkdir -p \"\${1}\"
		fi
	fi
}
project_directories() {
	directories=(\"\${HOME_DIR}\" \"\${BUILD_DIR}\" \"\${FILES_DIR}\" \"\${INSTALL_DIR}/bin\" \"\${INSTALL_DIR}/include\" \"\${INSTALL_DIR}/lib\" \"\${INSTALL_DIR}/lib64\" \"\${LOCAL_INSTALL_DIR}/bin\" \"\${LOCAL_INSTALL_DIR}/include\" \"\${LOCAL_INSTALL_DIR}/lib\" \"\${LOCAL_INSTALL_DIR}/lib64\" \"\${ARCHIVE_DIR}\" \"\${LOCAL_ARCHIVE_DIR}\")
	for i in \"\${directories[@]}\"; do
		make_directory \"\${i}\"
	done
}
clean_scripts() {
	for i in \"\${LOCAL_ARCHIVE_DIR}/script\"*.sh; do
		remove \"\${i}\" 1
		continue
	done
}
get_branch() {
	if [[ ! \"\${BRANCH}\" ]] || [[ \"\${BRANCH}\" == 0 ]]; then
		if [[ -d \"\${SRC_DIR}\" ]]; then
			BRANCH=\"\$(git -C \"\${SRC_DIR}\" branch --show-current 2>/dev/null)\"
		else
			BRANCH=\$(git ls-remote --symref \"\${PROJECT_URL}\" HEAD 2>/dev/null | grep \"refs/heads/\" | sed 's/.*\///g' | sed 's/[[:space:]]\+/ /g' | cut -f 1 -d \" \")
		fi
	fi
	if [[ ! \"\${BRANCH}\" ]] || [[ \"\${BRANCH}\" == 0 ]]; then
		BRANCH=\"master\"
	fi
}
set_variables() {
	OS=\"\${OS:-\$(source /etc/os-release; echo \"\${ID,,}\")}\"
	CPU_ARCH=\"\${CPU_ARCH:-\$(uname -m)}\"
	ABUCUS_SCRIPT=\"\$(command -v abucus)\"
	PROJECT_DIR=\"\$(cd -- \"\$(dirname -- \"\${0}\")\" && pwd -P)\"
	PROJECT_SCRIPT=\"\${PROJECT_DIR}/\${0##*/}\"
	SRC_DIR=\"\${PROJECT_DIR}/src.\${PROJECT_NAME}\"
	FILES_DIR=\"\${PROJECT_DIR}/files.\${PROJECT_NAME}\"
	HOME_DIR=\"\${PROJECT_DIR}/home.\${PROJECT_NAME}\"
	BUILD_DIR=\"\${PROJECT_DIR}/build.\${PROJECT_NAME}\"
	INSTALL_DIR=\"\${INSTALL_DIR:-/usr}\"
	LOCAL_INSTALL_DIR=\"\${PROJECT_DIR}/install.\${PROJECT_NAME}\"
	ARCHIVE_DIR=\"\${ARCHIVE_DIR:-\${PROJECT_DIR}/archive.\${PROJECT_NAME}}\"
	LOCAL_ARCHIVE_DIR=\"\${PROJECT_DIR}/archive.\${PROJECT_NAME}\"
	CUSTOM_VAR=\"\${CUSTOM_VAR:-\${OS}}\"
	BUILD_TYPE=\"\${BUILD_TYPE:-Release}\"
	ABUCUS_EDITOR=\"\${ABUCUS_EDITOR:-\$(command -v nano)}\"
	local file_managers=(\"nautilus\" \"dolphin\" \"thunar\" \"nemo\" \"caja\" \"pcmanfm\" \"pcmanfm-qt\")
	for i in \"\${file_managers[@]}\"; do
		if [[ \"\$(command -v \"\${i}\")\" ]]; then
			ABUCUS_FM=\"\$(command -v \"\${i}\")\"
			break
		fi
	done
	ADMIN=()
	if [[ \"\${UID}\" != 0 ]]; then
		if [[ \"\$(command -v sudo)\" ]]; then
			ADMIN=(sudo)
		elif [[ \"\$(command -v doas)\" ]]; then
			ADMIN=(doas)
		else
			say \"\${R}Cannot get root access\${N}\"
		fi
	fi
	if [[ -d \"\${SRC_DIR}\" ]]; then
		SRC_VERSION=\"\$(git -C \"\${SRC_DIR}\" rev-parse --short=8 HEAD 2>/dev/null)\"
	fi
	if [[ ! \"\${SRC_VERSION}\" ]] && [[ -d \"\${SRC_DIR}\" ]]; then
		SRC_VERSION=\"\$(stat \"\${SRC_DIR}\" | grep -E \"^Modify\" | cut -f 2 -d \" \")\"
	elif [[ ! \"\${SRC_VERSION}\" ]]; then
		SRC_VERSION=\"N/A\"
	fi
	get_branch
	export ABUCUS_LOGO=\"------------------------------------------------------------
    \     __ )   |   |   ___|  |   |   ___| 
   _ \    __ \   |   |  |      |   | \___ \ 
  ___ \   |   |  |   |  |      |   |       |
_/    _\ ____/  \___/  \____| \___/  _____/
\${PROJECT_SCRIPT}
\${W}\${PROJECT_NAME}:\${N} [\${G}\${PROJECT_URL}\${N}]
\${W}Abucus Version:\${N} \${E}shasum\${N} [\${G}\${ABUCUS_VERSION}\${N}]
\${W}Source Version:\${N} \${E}commit\${N} [\${G}\${SRC_VERSION}\${N}]
------------------------------------------------------------\"
}
run_abucus() {
	say \"\${ABUCUS_LOGO}\"
	say \"\${W}Usage:\${N}\t\tabucus [\${G}command(s)\${N}] [\${G}option(s)\${N}|\${G}project(s)\${N}]\"
	say \"\${W}Command:\${N}\t[\${G}abucus \${ARGUMENTS}\${N}]\"
	say \"\${W}Current Variables:\${N}\"
	say \"[\${G}BUILD_TYPE\${N}]\t\t\${BUILD_TYPE}\"
	say \"[\${G}BRANCH\${N}]\t\t\${BRANCH}\"
	say \"[\${G}CUSTOM_VAR\${N}]\t\t\${CUSTOM_VAR}\"
	say \"[\${G}INSTALL_DIR\${N}]\t\t\${INSTALL_DIR}\"
	say \"[\${G}ARCHIVE_DIR\${N}]\t\t\${ARCHIVE_DIR}\"
	if [[ \"\${PROJECT_NOTES}\" ]]; then
		say \"[\${G}PROJECT_NOTES\${N}]\t\t\${PROJECT_NOTES}\"
	fi
	if [[ \"\${ABUCUS}\" ]]; then
		say \"\${W}------------------------------------------------------------\${N}\"
		say \"\${W}Running dependencies\${N}\"
		say \"\${W}------------------------------------------------------------\${N}\"
		abucus_dependencies
	fi
	if [[ \"\${CLEAN_SCRIPTS}\" ]]; then
		say \"\${W}------------------------------------------------------------\${N}\"
		say \"\${W}Cleaning old scripts\${N} [\${R}\${LOCAL_ARCHIVE_DIR}/script*.sh\${N}]\"
		say \"\${W}------------------------------------------------------------\${N}\"
		clean_scripts
	fi
	if [[ \"\${OPEN}\" ]]; then
		if [[ ! \"\${ABUCUS_FM}\" ]]; then
			say \"\${R}File manager not set [ABUCUS_FM]\${N}\"
			exit 1
		fi
		say \"\${W}------------------------------------------------------------\${N}\"
		say \"\${W}Opening\${N} [\${G}\${PROJECT_DIR}\${N}] with [\${G}\${ABUCUS_FM}\${N}]\"
		\"\${ABUCUS_FM}\" \"\${PROJECT_DIR}\" &
		say \"\${W}------------------------------------------------------------\${N}\"
	fi
	if [[ \"\${EDIT}\" ]]; then
		if [[ ! \"\${ABUCUS_EDITOR}\" ]]; then
			say \"\${R}Text editor not set [ABUCUS_EDITOR]\${N}\"
			exit 1
		fi
		say \"\${W}------------------------------------------------------------\${N}\"
		say \"\${W}Editing\${N} [\${G}\${PROJECT_SCRIPT}\${N}] with [\${G}\${ABUCUS_EDITOR}\${N}]\"
		\"\${ABUCUS_EDITOR}\" \"\${PROJECT_SCRIPT}\"
		say \"\${W}------------------------------------------------------------\${N}\"
	fi
	if [[ \"\${CLONE}\" ]]; then
		say \"\${W}------------------------------------------------------------\${N}\"
		say \"\${W}Cloning\${N} [\${G}\${PROJECT_URL}\${N}]\"
		say \"\${W}------------------------------------------------------------\${N}\"
		clone_project
	fi
	if [[ \"\${UPDATE}\" ]]; then
		say \"\${W}------------------------------------------------------------\${N}\"
		say \"\${W}Updating\${N}\"
		say \"\${W}------------------------------------------------------------\${N}\"
		update_project
	fi
	if [[ \"\${DEPEND}\" ]]; then
		say \"\${W}------------------------------------------------------------\${N}\"
		say \"\${W}Installing dependencies\${N} for [\${G}\${OS}\${N}]\"
		say \"\${W}------------------------------------------------------------\${N}\"
		dependencies
	fi
	if [[ \"\${CLEAN}\" ]]; then
		say \"\${W}------------------------------------------------------------\${N}\"
		say \"\${W}Cleaning\${N}\"
		say \"\${W}------------------------------------------------------------\${N}\"
		clean_project
	fi
	if [[ \"\${CONFIGURE}\" ]]; then
		say \"\${W}------------------------------------------------------------\${N}\"
		say \"\${W}Configuring\${N}\"
		say \"\${W}------------------------------------------------------------\${N}\"
		configure_project
	fi
	if [[ \"\${BUILD}\" ]]; then
		say \"\${W}------------------------------------------------------------\${N}\"
		say \"\${W}Building\${N}\"
		say \"\${W}------------------------------------------------------------\${N}\"
		build_project
	fi
	if [[ \"\${INSTALL}\" ]]; then
		say \"\${W}------------------------------------------------------------\${N}\"
		say \"\${W}Installing\${N} to [\${G}\${INSTALL_DIR}\${N}]\"
		say \"\${W}------------------------------------------------------------\${N}\"
		install_project
	fi
	if [[ \"\${RUN}\" ]]; then
		say \"\${W}------------------------------------------------------------\${N}\"
		say \"\${W}Running\${N}\"
		say \"\${W}------------------------------------------------------------\${N}\"
		run_project
	fi
	if [[ \"\${ARCHIVE}\" ]]; then
		say \"\${W}------------------------------------------------------------\${N}\"
		say \"\${W}Archiving\${N} to [\${G}\${ARCHIVE_DIR}\${N}]\"
		say \"\${W}------------------------------------------------------------\${N}\"
		archive_project
	fi
}
print_usage() {
	say \"\${ABUCUS_LOGO}\"
	say \"\${W}Usage:\${N}\tabucus [\${G}command(s)\${N}] [\${G}option(s)\${N}|\${G}project(s)\${N}]\"
	say \"\${W}Commands:\${N} [\${E}Commands execute in this order\${N}]\"
	say \"[\${G} h H \${N}]\tPrint this information\"
	say \"[\${G} z Z \${N}]\tBUILD_TYPE \${W}=\${N} \${E}[\${G}Debug\${N}]\"
	say \"[\${G} l L \${N}]\tINSTALL_DIR \${W}=\${N} \${E}[\${G}\${PROJECT_DIR}/install.\${PROJECT_NAME}\${N}]\"
	say \"[\${G} y Y \${N}]\tARCHIVE_DIR \${W}=\${N} \${E}[\${G}\${PROJECT_DIR}/archive.\${PROJECT_NAME}\${N}]\"
	say \"[\${G} f F \${N}]\tClean old scripts [\${E}Removes all scripts in ARCHIVE_DIR\${N}]\"
	say \"[\${G} q Q \${N}]\tOpen project directory with file manager [\${E}Opens with ABUCUS_FM\${N}]\"
	say \"[\${G} e E \${N}]\tEdit project script [\${E}Opens ABUCUS_EDITOR to open project script\${N}]\"
	say \"[\${G} c C \${N}]\tClone project [\${E}Clones projects provided by url and parses name\${N}]\"
	say \"[\${G} u U \${N}]\tUpdate project [\${E}Update the git remote and all submodules\${N}]\"
	say \"[\${G} d D \${N}]\tInstall dependencies [\${E}Install host dependencies with auto pm detection\${N}]\"
	say \"[\${G} n N \${N}]\tClean project [\${E}User defined, defaults to rm and mkdir BUILD_DIR\${N}]\"
	say \"[\${G} m M \${N}]\tConfigure project [\${E}User defined, defaults to cmake\${N}]\"
	say \"[\${G} b B \${N}]\tBuild project [\${E}User defined, defaults to ninja\${N}]\"
	say \"[\${G} i I \${N}]\tInstall project [\${G}INSTALL_DIR\${N}] [\${E}User defined, defaults to ninja\${N}]\"
	say \"[\${G} r R \${N}]\tRun project [\${E}User defined, defaults to set home directory to local directory\${N}]\"
	say \"[\${G} a A \${N}]\tArchive project [\${G}ARCHIVE_DIR\${N}] [\${E}Archive project with tar and zstd\${N}]\"
	say \"[\${G} k K \${N}]\tRun commands against project's abucus dependencies recursively [\${E}Does not pass BRANCH\${N}]\"
	say \"\${W}Options:\${N}\"
	say \"[\${G} o O \${N}] [\${G}BRANCH\${N}]\tSet git branch [\${W}Default:\${N} \${G}master\${N}] [\${E}Ex: abucus c o beta\${N}]\"
	say \"[\${G} g G \${N}] [\${G}CUSTOM_VAR\${N}]\tSet custom variable [\${W}Default:\${N} \${G}\${OS}\${N}] [\${E}Ex: abucus b g testing\${N}]\"
	say \"[\${G} p P \${N}] [\${G}INSTALL_DIR\${N}]\tSet install directory [\${E}Ex: abucus nmbi p /usr/local\${N}]\"
	say \"[\${G} v V \${N}] [\${G}ARCHIVE_DIR\${N}]\tSet archive directory [\${E}Ex: abucus a v /home/knuxyl/archives\${N}]\"
	say \"\${W}Current Variables:\${N}\"
	say \"[\${G}ABUCUS_FM\${N}]\t\t\${ABUCUS_FM}\"
	say \"[\${G}ABUCUS_EDITOR\${N}]\t\t\${ABUCUS_EDITOR}\"
	say \"[\${G}BUILD_TYPE\${N}]\t\t\${BUILD_TYPE}\"
	say \"[\${G}BRANCH\${N}]\t\t\${BRANCH}\"
	say \"[\${G}CUSTOM_VAR\${N}]\t\t\${CUSTOM_VAR}\"
	say \"[\${G}INSTALL_DIR\${N}]\t\t\${INSTALL_DIR}\"
	say \"[\${G}ARCHIVE_DIR\${N}]\t\t\${ABUCUS_ARCHIVE_DIR}\"
	exit 0
}
parse_arguments() {
	if [[ ! \"\${1}\" ]]; then
		print_usage
	fi
	for (( i=0; i<\${#1}; i++ )); do
		arg=\"\${1:\${i}:1}\"
		case \"\${arg}\" in
			[hH]) HELP=1;;
			[zZ]) BUILD_TYPE=\"Debug\";;
			[lL]) LOCAL_INSTALL=1;;
			[yY]) LOCAL_ARCHIVE=1;;
			[fF]) CLEAN_SCRIPTS=1;;
			[qQ]) OPEN=1;;
			[eE]) EDIT=1;;
			[cC]) CLONE=1;;
			[uU]) UPDATE=1;;
			[dD]) DEPEND=1;;
			[nN]) CLEAN=1;;
			[mM]) CONFIGURE=1;;
			[bB]) BUILD=1;;
			[iI]) INSTALL=1;;
			[rR]) RUN=1;;
			[aA]) ARCHIVE=1;;
			[kK]) ABUCUS=1;;
			*) echo -e \"\${R}Invalid argument\${N} [ \${G}\${1}\${N} ]\"; shift;;
		esac
	done
	shift
	while [[ \$# -gt 0 ]]; do
		case \"\${1}\" in
			[oO]) BRANCH=\"\${2}\"; shift 2;;
			[gG]) CUSTOM_VAR=\"\${2}\"; shift 2;;
			[pP]) INSTALL_DIR=\"\${2}\"; shift 2;;
			[vV]) ARCHIVE_DIR=\"\${2}\"; shift 2;;
			*) echo \"\${R}Invalid argument\${N} [ \${G}\${1}\${N} ]\"; shift;;
		esac
	done
	if [[ \"\${LOCAL_INSTALL}\" ]]; then
		INSTALL_DIR=\"\${LOCAL_INSTALL_DIR}\"
	fi
	if [[ \"\${LOCAL_ARCHIVE}\" ]]; then
		ARCHIVE_DIR=\"\${LOCAL_ARCHIVE_DIR}\"
	fi
	get_branch
	if [[ ! \"\${PROJECT_URL}\" ]] && [[ -d \"\${SRC_DIR}\" ]]; then
		PROJECT_URL=\"\$(git -C \"\${SRC_DIR}\" remote get-url origin)\"
	fi
	if [[ \"\${HELP}\" ]]; then
		print_usage
	fi
}
check_dependencies() {
	abucus_dependencies=(\"sed\" \"grep\" \"git\" \"shasum\" \"ninja\" \"cmake\" \"cut\" \"dirname\" \"basename\" \"nproc\" \"cut\" \"echo\" \"stat\" \"printf\" \"ls\" \"cd\" \"date\" \"tar\" \"zstd\")
	for i in \"\${abucus_dependencies[@]}\"; do
		if [[ ! \"\$(command -v \"\${i}\")\" ]]; then
			say \"\${R}Missing \${i}\${N}\"
			exit 1
		fi
	done
}
say() {
    printf '%b\n' \"\$*\"
}
ABUCUS_VERSION=\"${ABUCUS_VERSION}\"
ARGUMENTS=\"\${@}\"
COMMANDS=\"\${1}\"
colors
check_dependencies
set_variables
parse_arguments \"\${@}\"
project_directories
run_abucus
" > "${PROJECT_SCRIPT}"
	fi
}
clean_project="	if [[ -d \"\${BUILD_DIR}\" ]]; then
		remove \"\${BUILD_DIR}\"
	fi
	make_directory \"\${BUILD_DIR}\""
configure_project="	cmake -S \"\${SRC_DIR}\" -B \"\${BUILD_DIR}\" -G Ninja -L -DCMAKE_BUILD_TYPE=\"\${BUILD_TYPE}\" -DCMAKE_INSTALL_PREFIX=\"\${INSTALL_DIR}\"
	#meson setup \"\${BUILD_DIR}\" -Dbuildtype=\"\${BUILD_TYPE}\" -Dprefix=\"\${INSTALL_DIR}\" \"\${SRC_DIR}\"}"
build_project="	ninja -C \"\${BUILD_DIR}\" -j\"\$(nproc)\""
install_project="	if [[ -w \"\${INSTALL_DIR}\" ]]; then
		ninja -C \"\${BUILD_DIR}\" -j\"\$(nproc)\" install
	else
		\"\${ADMIN[@]}\" ninja -C \"\${BUILD_DIR}\" -j\"\$(nproc)\" install
	fi"
run_project="	export HOME=\"\${HOME_DIR}\"
	BINARY=\"\"
	if [[ ! -f \"\${BINARY}\" ]]; then
		say \"[ \${G}\${BINARY}\${N} ] \${R}does not exist\${N}\"
		exit 1
	fi
	\"\${BINARY}\""
abucus_project="	if [[ ! \"\${ABUCUS_SCRIPT}\" ]]; then
		say \"\${R}Location of abucus script not set [ABUCUS_SCRIPT]\${N}\"
		exit 1
	fi
	abucus_deps=()
	for i in \"\${abucus_deps[@]}\"; do
		if [[ \"\${i}\" ]]; then
			\"\${ABUCUS_SCRIPT}\" \${COMMANDS} p \"\${INSTALL_DIR}\" g \"\${CUSTOM_VAR}\" v \"\${ARCHIVE_DIR}\" \"\${i}\"
		fi
	done"
dependency_project="	emerge_deps=\"\"
	apt_deps=\"\"
	dnf_deps=\"\"
	apk_deps=\"\"
	opkg_deps=\"\"
	pacman_deps=\"\"
	zypper_deps=\"\"
	if [[ \"\$(command -v emerge)\" ]]; then
		deps=\"\${emerge_deps/>/\\>}\"
		\"\${ADMIN[@]}\" emerge -av \${deps}
	elif [[ \"\$(command -v apt)\" ]]; then

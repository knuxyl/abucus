		\"\${ADMIN[@]}\" apt install \${deps}
	elif [[ \"\$(command -v dnf)\" ]]; then
		deps=\"\${dnf_deps/>/\\>}\"
		\"\${ADMIN[@]}\" dnf install \${deps}
	elif [[ \"\$(command -v apk)\" ]]; then
		deps=\"\${apk_deps/>/\\>}\"
		\"\${ADMIN[@]}\" apk add \${deps}
	elif [[ \"\$(command -v opkg)\" ]]; then
		deps=\"\${opkg_deps/>/\\>}\"
		\"\${ADMIN[@]}\" opkg install \${deps}
	elif [[ \"\$(command -v pacman)\" ]]; then
		deps=\"\${pacman_deps/>/\\>}\"

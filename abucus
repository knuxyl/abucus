characters() {
	echo "${1}" | sed 's/[^a-zA-Z0-9]//g'
}
sanitize() {
	echo "${1}" | sed 's/[<>:"\/\\|?*]//g' | sed 's/[[:cntrl:]]//g'
}
update_script() {
	SCRIPT_VERSION="$(grep "^ABUCUS_VERSION=" "${PROJECT_SCRIPT}" | cut -f 2 -d '"')"
	if [[ "${SCRIPT_VERSION}" != "${ABUCUS_VERSION}" ]]; then
		local version="$(echo "${SCRIPT_VERSION}" | cut -f 2 -d ".")"
		local archive_dir="${PROJECT_DIR}/archive.${PROJECT_NAME}"
		if [[ "${version}" == "" ]]; then
			local count=0
			output="${archive_dir}/script.${count}.${PROJECT_NAME}.sh"
			while [[ -f "${output}" ]]; do
				count=$((count + 1))
				output="${archive_dir}/script.${count}.${PROJECT_NAME}.sh"
			done
		else
			output="${archive_dir}/script.${version}.${PROJECT_NAME}.sh"
		fi
		build_function="$(sed -n '/^build_project()[[:space:]]*{/,/^}$/p' "${PROJECT_SCRIPT}" | sed '1d;$d')"
		clean_function="$(sed -n '/^clean_project()[[:space:]]*{/,/^}$/p' "${PROJECT_SCRIPT}" | sed '1d;$d')"
		configure_function="$(sed -n '/^configure_project()[[:space:]]*{/,/^}$/p' "${PROJECT_SCRIPT}" | sed '1d;$d')"
		install_function="$(sed -n '/^install_project()[[:space:]]*{/,/^}$/p' "${PROJECT_SCRIPT}" | sed '1d;$d')"
		run_function="$(sed -n '/^run_project()[[:space:]]*{/,/^}$/p' "${PROJECT_SCRIPT}" | sed '1d;$d')"
		abucus_function="$(sed -n '/^abucus_dependencies()[[:space:]]*{/,/^}$/p' "${PROJECT_SCRIPT}" | sed '1d;$d')"
		dependency_function="$(sed -n '/^dependencies()[[:space:]]*{/,/^}$/p' "${PROJECT_SCRIPT}" | sed '1d;$d')"
		PROJECT_URL="$(grep -m1 "^PROJECT_URL=" "${PROJECT_SCRIPT}" | cut -f 2 -d '"')"
		PROJECT_NOTES="$(grep -m1 "^PROJECT_NOTES=" "${PROJECT_SCRIPT}" | cut -f 2 -d '"')"
		local count=0
		mv "${PROJECT_SCRIPT}" "${output}"
		setup_project
	fi
}
run_abucus() {
	say "${W}${ABUCUS_LOGO}${N}"
	say "${W}Command:${N}\t[${G}abucus ${ARGUMENTS}${N}]"
	if [[ "${OPEN}" ]]; then
		if [[ ! "${ABUCUS_FM}" ]]; then
			say "${R}File manager not set [ABUCUS_FM]${N}"
			exit 1
		fi
		say "${W}Opening${N} [${G}${ABUCUS_DIR}${N}] with [${G}${ABUCUS_FM}${N}]"
		"${ABUCUS_FM}" "${ABUCUS_DIR}"
	fi
	if [[ "${EDIT_SCRIPT}" ]]; then
		if [[ ! "${ABUCUS_EDITOR}" ]]; then
			say "${R}Text editor not set [ABUCUS_EDITOR]${N}"
			exit 1
		fi
		say "${W}Editing${N} [${G}${ABUCUS_SCRIPT}${N}] with [${G}${ABUCUS_EDITOR}${N}]"
		"${ABUCUS_EDITOR}" "${ABUCUS_SCRIPT}"
	fi
	if [[ "${EDIT_CONF}" ]]; then
		if [[ ! "${ABUCUS_EDITOR}" ]]; then
			say "${R}Text editor not set [ABUCUS_EDITOR]${N}"
			exit 1
		fi
		say "${W}Editing${N} [${G}${ABUCUS_CONF}${N}] with [${G}${ABUCUS_EDITOR}${N}]"
		"${ABUCUS_EDITOR}" "${ABUCUS_CONF}"
	fi
	if [[ ! "${COMMANDS}" ]]; then
		exit 0
	fi
	if [[ "${PROJECTS[0]}" ]]; then
		for PROJECT_NAME in "${PROJECTS[@]}"; do
			if [[ "${BRANCH}" != 0 ]]; then
				BRANCH_NAME=".${BRANCH}"
			else
				BRANCH_NAME=""
			fi
			if [[ "${PROJECT_NAME}" == *"/"* ]]; then
				PROJECT_URL="${PROJECT_NAME%/}"
				PROJECT_NAME="${PROJECT_URL%.git}"
				PROJECT_NAME="${PROJECT_NAME#*://}"
				PROJECT_OWNER="${PROJECT_NAME%/*}"
				PROJECT_OWNER="${PROJECT_OWNER##*/}"
				PROJECT_NAME="${PROJECT_NAME##*/}"
				if [[ "${PROJECT_OWNER}" != "" ]] && [[ "${PROJECT_OWNER}" != *"."* ]]; then
					PROJECT_NAME="${PROJECT_NAME##*/}${BRANCH_NAME}.${PROJECT_OWNER}"
				else
					PROJECT_NAME="${PROJECT_NAME##*/}${BRANCH_NAME}"
				fi
			fi
			PROJECT_NAME="$(sanitize "${PROJECT_NAME}")"
			PROJECT_DIR="${ABUCUS_PROJECTS_DIR}/${PROJECT_NAME}"
			if [[ ! "${COMMANDS}" =~ .*[cC].* ]]; then
				local PROJECTS=()
				local count=0
				say "${W}Matching Projects:${N}"
				for PROJECT_DIR in "${ABUCUS_PROJECTS_DIR}/"*; do
					local project_dir="$(characters "$(echo "${PROJECT_DIR}" | tr '[[:upper:]]' '[[:lower:]]')")"
					local project_name="$(characters "$(echo "${PROJECT_NAME}" | tr '[[:upper:]]' '[[:lower:]]')")"
					if [[ "${project_dir}" =~ "${project_name}" ]]; then
						PROJECT_NAME="${PROJECT_DIR##*/}"
						say "[${G} ${count}${N} ]\t${PROJECT_NAME}"
						PROJECTS+=("${PROJECT_NAME}")
						count=$((count + 1))
					fi
				done
				if [[ ! "${PROJECTS[0]}" ]]; then
					say "${R}No projects found matching [${PROJECT_NAME}]${N}"
					exit 1
				fi
				local prompt=$(say "${W}Choose a project [${N}${G}0-$((count - 1))${N}${W}]: ${N}")
				read -p "${prompt}" p
				if [[ "${p}" =~ [0-9]+ ]]; then
					PROJECT_NAME="${PROJECTS["${p}"]}"
					PROJECT_DIR="${ABUCUS_PROJECTS_DIR}/${PROJECT_NAME}"
				else
					say "${R}Invalid selection${N} (${P}${p}${N})"
					print_usage
					exit 1
				fi
			fi
			PROJECT_SCRIPT="${PROJECT_DIR}/script.${PROJECT_NAME}.sh"
			setup_project
			update_script
			say "${W}Running${N}\t[${G}${PROJECT_SCRIPT}${N}]"
			bash "${PROJECT_SCRIPT}" "${COMMANDS}" o "${BRANCH}" p "${INSTALL_DIR}" g "${CUSTOM_VAR}" v "${ABUCUS_ARCHIVE_DIR}"
		done
	else
		say "${W}Projects:${N}"
		local PROJECTS=()
		local total_count=-1
		for PROJECT_DIR in "${ABUCUS_PROJECTS_DIR}/"*; do
			total_count=$((total_count + 1))
		done
		par_len="${#total_count}"
		local count=0
		for PROJECT_DIR in "${ABUCUS_PROJECTS_DIR}/"*; do
			count=$(printf "%${par_len}d" "${count}")
			if [[ ! -d "${PROJECT_DIR}" ]]; then
				say "${R}Project directory not found${N} [${G}${PROJECT_DIR}${N}]"
				continue
			fi
			PROJECT_NAME="${PROJECT_DIR##*/}"
			say "[${G} ${count}${N} ]\t${PROJECT_NAME}"
			PROJECTS+=("${PROJECT_NAME}")
			count=$((count + 1))
		done
		if [[ ! "${PROJECTS[0]}" ]]; then
			say "${R}No projects found${N}"
			exit 1
		fi
		say "[${G} a A ${N}]\tAll Projects"
		local prompt=$(say "${W}Choose a project [${N}${G}0-$((count - 1))${N}${W}][${N}${G} a A ${N}${W}]: ${N}")
		read -p "${prompt}" p
		PROJECT_NAME="${PROJECTS["${p}"]}"
		if [[ "${p}" =~ [0-9]+ ]]; then
			PROJECT_DIR="${ABUCUS_PROJECTS_DIR}/${PROJECT_NAME}"
			PROJECT_SCRIPT="${PROJECT_DIR}/script.${PROJECT_NAME}.sh"
			setup_project
			update_script
			say "${W}Running${N}\t[${G}${PROJECT_SCRIPT}${N}] "
			bash "${PROJECT_SCRIPT}" "${COMMANDS}" o "${BRANCH}" p "${INSTALL_DIR}" g "${CUSTOM_VAR}" v "${ABUCUS_ARCHIVE_DIR}"
		elif [[ "${p}" == [aA] ]]; then
			for PROJECT_NAME in "${PROJECTS[@]}"; do
				PROJECT_DIR="${ABUCUS_PROJECTS_DIR}/${PROJECT_NAME}"
				PROJECT_SCRIPT="${PROJECT_DIR}/script.${PROJECT_NAME}.sh"
				setup_project
				update_script
				say "${W}Running${N}\t[${G}${PROJECT_SCRIPT}${N}] "
				bash "${PROJECT_SCRIPT}" "${COMMANDS}" o "${BRANCH}" p "${INSTALL_DIR}" g "${CUSTOM_VAR}" v "${ABUCUS_ARCHIVE_DIR}"
			done
		else
			say "${R}Invalid selection${N} (${P}${p}${N})"
			print_usage
			exit 1
		fi
	fi
}
colors() {
	L="$(tput setaf 0)"
	R="$(tput setaf 1)"
	G="$(tput setaf 2)"
	Y="$(tput setaf 3)"
	B="$(tput setaf 4)"
	P="$(tput setaf 5)"
	E="$(tput setaf 6)"
	W="$(tput bold)$(tput setaf 7)"
	D="$(tput setaf 8)"
	N="$(tput sgr0)"
}
parse_arguments() {
	if [[ ! "${COMMANDS}" ]]; then
		print_usage
		exit 0
	fi
	PROJECTS=()
	for (( i=0; i<${#COMMANDS}; i++ )); do
		arg="${COMMANDS:${i}:1}"
		case "${arg}" in
			[hH]) HELP=1;;
			[xX]) OPEN=1;;
			[jJ]) "${ABUCUS_EDITOR}" "${ABUCUS_SCRIPT}";;
			[xX]) "${ABUCUS_EDITOR}" "${ABUCUS_CONF}";;
			[zZ]) BUILD_TYPE="Debug";;
			[tT]) INSTALL_DIR="${ABUCUS_INSTALL_DIR}";;
			
		esac
	done
	shift
	while [[ $# -gt 0 ]]; do
		case "${1}" in
			[oO]) BRANCH="${2}"; shift 2;;
			[gG]) CUSTOM_VAR="${2}"; shift 2;;
			[pP]) INSTALL_DIR="${2}"; shift 2;;
			[vV]) ARCHIVE_DIR="${2}"; shift 2;;
			[sS]) ABUCUS_PROJECTS_DIR="${ABUCUS_DIR}/${2##*/}"; shift 2;;
			*) PROJECTS+=("${1}"); shift;;
		esac
	done
	if [[ ! "${BRANCH}" ]]; then
		BRANCH=0
	fi
	if [[ "${HELP}" ]]; then
		print_usage
	fi
	COMMANDS=$(echo "${COMMANDS}" | tr -d 't' | tr -d 'T' | tr -d 's' | tr -d 'S' | tr -d 'j' | tr -d 'J' | tr -d 'x' | tr -d 'X')
}
say() {
    printf '%b\n' "$*"
}

	say "[${G} z Z ${N}]\tBUILD_TYPE ${W}=${N}${E} [${G}Debug${N}]"
	say "[${G} t T ${N}]\tINSTALL_DIR ${W}=${N}${E} [${G}ABUCUS_INSTALL_DIR${N}]"

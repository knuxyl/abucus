create_directories() {
	directories=("${ABUCUS_HOME}" "${ABUCUS_PROJECTS_DIR}" "${INSTALL_DIR}/bin" "${INSTALL_DIR}/include" "${INSTALL_DIR}/lib" "${INSTALL_DIR}/lib64" "${ABUCUS_INSTALL_DIR}/bin" "${ABUCUS_INSTALL_DIR}/include" "${ABUCUS_INSTALL_DIR}/lib" "${ABUCUS_INSTALL_DIR}/lib64" "${ABUCUS_ARCHIVE_DIR}")
	for i in "${directories[@]}"; do
		make_directory "${i}"
	done
}
remove() {
	local prompt="$(say "${W}Deleting directory${N} [${R}${1}${N}] Continue? [${G}Y/n${N}]: ")"
	if [[ -w "$(dirname "${1}")" ]]; then
		if [[ ! "${2}" ]]; then
			read -p "${prompt}" p
		fi
		if [[ "${p}" != [nN] ]] || [[ "${2}" ]]; then
			rm -Rf "${1}"
		else
			say "${W}Skipping deletion of${N} [${G}${1}${N}]"
		fi
	else
		if [[ ! "${2}" ]]; then
			read -p "${prompt}" p
		fi
		if [[ "${p}" != [nN] ]] || [[ "${2}" ]]; then
			"${ADMIN[@]}" rm -Rf "${1}"
		else
			say "${W}Skipping deletion of${N} [${G}${1}${N}]"
		fi
	fi
}
make_directory() {
	if [[ ! -d "${1}" ]]; then
		say "${W}Creating directory${N} [${G}${1}${N}]"
		local parent="$(dirname "${1}")"
		while [[ ! -d "${parent}" ]]; do
			parent="$(dirname "${parent}")"
		done
		if [[ -w "${parent}" ]]; then
			mkdir -p "${1}"
		else
			"${ADMIN[@]}" mkdir -p "${1}"
		fi
	fi
}
check_dependencies() {
	abucus_dependencies=("sed" "grep" "git" "shasum" "ninja" "cmake" "cut" "dirname" "basename" "nproc" "cut" "echo" "stat" "printf" "ls" "cd" "date" "tar" "zstd")
	for i in "${abucus_dependencies[@]}"; do
		if [[ ! "$(command -v "${i}")" ]]; then
			say "${R}Missing ${i}${N}"
			exit 1
		fi
	done
}
ARGUMENTS="${@}"
